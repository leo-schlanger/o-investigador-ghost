<div class="group cursor-pointer min-w-0">
    {{#if feature_image}}
    <a href="{{url}}" class="block mb-3 sm:mb-4 overflow-hidden rounded-md sm:rounded-lg bg-neutral-100">
        <div class="aspect-video relative">
            <img src="{{img_url feature_image size='sm'}}" alt="{{title}}"
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy">
        </div>
    </a>
    {{/if}}

    <div class="flex flex-wrap gap-1.5 sm:gap-2 mb-1.5 sm:mb-2">
        {{!-- Article type badge (Cronica, Reportagem, Opiniao) --}}
        {{#foreach tags}}
            {{#match slug "~" "tipo-"}}
                {{#match slug "tipo-cronica"}}
                <span class="text-xs font-semibold px-2 py-0.5 sm:py-1 bg-purple-100 text-purple-700 rounded">
                    Cronica
                </span>
                {{/match}}
                {{#match slug "tipo-reportagem"}}
                <span class="text-xs font-semibold px-2 py-0.5 sm:py-1 bg-blue-100 text-blue-700 rounded">
                    Reportagem
                </span>
                {{/match}}
                {{#match slug "tipo-opiniao"}}
                <span class="text-xs font-semibold px-2 py-0.5 sm:py-1 bg-orange-100 text-orange-700 rounded">
                    Opiniao
                </span>
                {{/match}}
            {{/match}}
        {{/foreach}}
        {{!-- Category badge (first non-type tag) --}}
        {{#foreach tags}}
            {{#unless (match slug "~" "tipo-")}}
                {{#if @first}}
                <a href="{{url}}" class="text-xs font-semibold px-2 py-0.5 sm:py-1 bg-primary-50 text-brand rounded hover:bg-primary-100 transition">
                    {{name}}
                </a>
                {{/if}}
            {{/unless}}
        {{/foreach}}
    </div>

    <h3 class="text-base sm:text-lg font-bold text-neutral-900 group-hover:text-brand transition mb-1.5 sm:mb-2 line-clamp-2">
        <a href="{{url}}">{{title}}</a>
    </h3>

    <p class="text-xs sm:text-sm text-neutral-600 mb-3 sm:mb-4 line-clamp-2">
        {{excerpt words="30"}}
    </p>

    <div class="flex items-center justify-between text-[11px] sm:text-xs text-neutral-500">
        <span>{{date published_at format="DD MMM"}}</span>
        <span>{{reading_time}} min</span>
    </div>
</div>