    {{!-- Category Sub-bar with Dropdowns --}}
    <div class="bg-brand-dark text-white/90 text-[11px] sm:text-xs md:text-sm py-2 sm:py-2.5 overflow-x-auto border-t border-white/10 scrollbar-hide">
        <div class="max-w-7xl mx-auto px-2 sm:px-4 md:px-6 flex gap-3 sm:gap-4 md:gap-6 lg:gap-8 justify-start sm:justify-center font-medium tracking-wide whitespace-nowrap">
            <a href="/politica/" class="hover:text-white transition whitespace-nowrap">Politica</a>
            <a href="/economia/" class="hover:text-white transition whitespace-nowrap">Economia</a>
