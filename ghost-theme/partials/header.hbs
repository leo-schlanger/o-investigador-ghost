                </div>
            </div>
        </nav>

        {{!-- TODO: Habilitar login de membros quando o sistema estiver funcional --}}
        {{!-- Menu mobile - Login/Signup desabilitado temporariamente
        <div class="mt-8 pt-6 border-t border-neutral-200 space-y-3">
            <a href="#/portal/signin"
                class="block text-center w-full py-3 text-sm font-semibold text-brand border border-brand rounded-lg hover:bg-brand hover:text-white transition">Entrar</a>
            <a href="#/portal/signup"
                class="block text-center w-full py-3 text-sm font-bold text-white bg-brand-accent rounded-lg hover:bg-accent-600 transition">Assinar</a>
        </div>
        --}}
    </div>
</div>

<script>
    // Mobile menu
    const menuBtn = document.getElementById('mobile-menu-btn');
    const menuClose = document.getElementById('mobile-menu-close');
    const menuOverlay = document.getElementById('mobile-menu-overlay');
    const menu = document.getElementById('mobile-menu');

    menuBtn?.addEventListener('click', () => menu?.classList.remove('hidden'));
    menuClose?.addEventListener('click', () => menu?.classList.add('hidden'));
    menuOverlay?.addEventListener('click', () => menu?.classList.add('hidden'));

    // Portuguese date formatting (pt-PT)
    (function() {
        var diasSemana = ['Domingo', 'Segunda-feira', 'Terça-feira', 'Quarta-feira', 'Quinta-feira', 'Sexta-feira', 'Sábado'];
        var meses = ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'];
        var mesesAbrev = ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'];

        var hoje = new Date();
        var diaSemana = diasSemana[hoje.getDay()];
        var dia = hoje.getDate();
        var mes = meses[hoje.getMonth()];
        var mesAbrev = mesesAbrev[hoje.getMonth()];
        var ano = hoje.getFullYear();

        var dateFull = document.getElementById('header-date-full');
        var dateShort = document.getElementById('header-date-short');

        if (dateFull) dateFull.textContent = diaSemana + ', ' + dia + ' de ' + mes + ' de ' + ano;
        if (dateShort) dateShort.textContent = dia + ' ' + mesAbrev + ' ' + ano;
    })();

    // Weather widget using Open-Meteo API (free, no API key needed)
    (function() {
        var cities = [
            { id: 'lisboa', lat: 38.7223, lon: -9.1393 },
            { id: 'porto', lat: 41.1579, lon: -8.6291 },
            { id: 'faro', lat: 37.0194, lon: -7.9304 },
            { id: 'cascais', lat: 38.6979, lon: -9.4215 }
        ];

        function loadWeather() {
            var url = 'https://api.open-meteo.com/v1/forecast?latitude=38.7223,41.1579,37.0194,38.6979&longitude=-9.1393,-8.6291,-7.9304,-9.4215&current_weather=true';

            fetch(url)
                .then(function(response) {
                    if (!response.ok) throw new Error('API error');
                    return response.json();
                })
                .then(function(data) {
                    if (Array.isArray(data)) {
                        data.forEach(function(item, i) {
                            var el = document.getElementById('weather-' + cities[i].id);
                            if (el && item.current_weather) {
                                el.textContent = Math.round(item.current_weather.temperature) + '°C';
                            }
                        });
                    }
                })
                .catch(function(e) {
                    console.warn('Weather error:', e);
                });
        }

        // Run after DOM is ready
        if (document.readyState === 'complete' || document.readyState === 'interactive') {
            setTimeout(loadWeather, 100);
        } else {
            document.addEventListener('DOMContentLoaded', function() {
                setTimeout(loadWeather, 100);
            });
        }
    })();
</script>