# ===========================================
# CMS API - Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values

# Node Environment
NODE_ENV=development

# ===========================================
# Database Configuration (MySQL)
# ===========================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=o_investigador
DB_USER=your_db_user
DB_PASSWORD=your_secure_password

# ===========================================
# API Configuration
# ===========================================
API_PORT=3000

# JWT Secret (REQUIRED - minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars

# CORS Origins (comma-separated)
CORS_ORIGIN=http://localhost:5173,http://localhost:2368

# ===========================================
# Ghost CMS Integration
# ===========================================
# Get API Key from Ghost Admin > Settings > Integrations
# IMPORTANT: In production, use the PUBLIC URL (https://yourdomain.com)
# Ghost validates that requests match its configured URL
GHOST_API_URL=http://localhost:2368
GHOST_API_KEY=your_ghost_admin_api_key

# ===========================================
# Admin User (Optional)
# ===========================================
# If set, these credentials will be used for the initial admin user
# If not set, a random password will be generated on first startup
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your_secure_admin_password

# ===========================================
# AWS S3 (Optional - for media storage)
# ===========================================
# AWS_REGION=eu-west-1
# AWS_BUCKET=your-bucket-name
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
