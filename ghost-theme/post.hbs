{{!< default}} {{#post}}
{{!-- Post ID for view tracking --}}
<meta name="post-id" content="{{id}}">

{{!-- Schema.org NewsArticle structured data --}}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    "headline": "{{title}}",
    "description": "{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt}}{{/if}}",
    "inLanguage": "pt-PT",
    "datePublished": "{{date published_at format='YYYY-MM-DDTHH:mm:ssZ'}}",
    "dateModified": "{{date updated_at format='YYYY-MM-DDTHH:mm:ssZ'}}",
    {{#if feature_image}}
    "image": {
        "@type": "ImageObject",
        "url": "{{feature_image}}",
        "width": 1200
    },
    {{/if}}
    "author": [{{#foreach authors}}{{#unless @first}},{{/unless}}{
        "@type": "Person",
        "name": "{{name}}"{{#if profile_image}},
        "image": "{{profile_image}}"{{/if}},
        "url": "{{url absolute='true'}}"
    }{{/foreach}}],
    "publisher": {
        "@type": "NewsMediaOrganization",
        "name": "{{@site.title}}",
        "url": "{{@site.url}}",
        "logo": {
            "@type": "ImageObject",
            "url": "{{@site.url}}/assets/images/logo-square.png",
            "width": 1024,
            "height": 1024
        }
    },
    "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "{{url absolute='true'}}"
    }{{#foreach tags limit="1"}},
    "articleSection": "{{name}}"{{/foreach}}
}
</script>

{{!-- BreadcrumbList --}}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "Inicio",
            "item": "{{@site.url}}"
        },
        {{#foreach tags limit="1"}}
        {
            "@type": "ListItem",
            "position": 2,
            "name": "{{name}}",
            "item": "{{url absolute='true'}}"
        },
        {{/foreach}}
        {
            "@type": "ListItem",
            "position": 3,
            "name": "{{title}}"
        }
    ]
}
</script>

<article class="py-6 sm:py-8 md:py-12 lg:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-3 sm:px-4 md:px-6 overflow-hidden">

        <header class="mb-4 sm:mb-6 md:mb-8 pb-4 sm:pb-6 md:pb-8 border-b border-neutral-200">
            <div class="flex flex-wrap gap-1.5 sm:gap-2 md:gap-3 mb-2 sm:mb-3 md:mb-4 items-center">
                {{!-- Article type badge (Cronica, Reportagem, Opiniao) --}}
                {{#foreach tags}}
                    {{#match slug "tipo-cronica"}}
                    <span class="px-2 sm:px-3 py-0.5 sm:py-1 bg-purple-50 text-purple-600 text-[11px] sm:text-xs font-semibold rounded-full">
                        Cronica
                    </span>
                    {{/match}}
                    {{#match slug "tipo-reportagem"}}
                    <span class="px-2 sm:px-3 py-0.5 sm:py-1 bg-primary-50 text-brand text-[11px] sm:text-xs font-semibold rounded-full">
                        Reportagem
                    </span>
                    {{/match}}
                    {{#match slug "tipo-opiniao"}}
                    <span class="px-2 sm:px-3 py-0.5 sm:py-1 bg-accent-50 text-accent-500 text-[11px] sm:text-xs font-semibold rounded-full">
                        Opiniao
                    </span>
                    {{/match}}
                {{/foreach}}
                {{!-- Category badge (first non-type tag) --}}
                {{#foreach tags}}
                    {{#unless (match slug "~" "tipo-")}}
                        {{#if @first}}
                        <a href="{{url}}" class="px-2 sm:px-3 py-0.5 sm:py-1 bg-primary-50 text-brand text-[11px] sm:text-xs font-semibold rounded-full hover:bg-primary-100 transition">
                            {{name}}
                        </a>
                        {{/if}}
                    {{/unless}}
                {{/foreach}}
                <span class="text-[11px] sm:text-xs md:text-sm text-neutral-500">{{reading_time}} min</span>
                <span class="text-[11px] sm:text-xs md:text-sm text-neutral-500">{{date published_at format="DD MMM YYYY"}}</span>
            </div>

            <h1 class="text-xl sm:text-2xl md:text-3xl lg:text-4xl xl:text-5xl font-bold mb-2 sm:mb-3 md:mb-4 text-neutral-900 leading-tight">
                {{title}}</h1>

            {{#if custom_excerpt}}
            <p class="text-sm sm:text-base md:text-lg lg:text-xl text-neutral-600 font-medium">{{custom_excerpt}}</p>
            {{/if}}
        </header>

        {{#if feature_image}}
        <figure class="mb-6 sm:mb-8 md:mb-10 lg:mb-12 -mx-3 sm:mx-0">
            <img src="{{img_url feature_image size='xl'}}" alt="{{title}}"
                class="w-full h-auto object-cover rounded-none sm:rounded-lg">
            {{#if feature_image_caption}}
            <figcaption class="text-center text-[11px] sm:text-xs md:text-sm text-neutral-500 mt-2 px-3 sm:px-0">{{feature_image_caption}}
            </figcaption>
            {{/if}}
        </figure>
        {{/if}}

        <div
            class="prose prose-sm sm:prose-base lg:prose-lg max-w-none mb-6 sm:mb-8 md:mb-10 lg:mb-12 prose-headings:font-bold prose-a:text-primary-500 prose-img:rounded-lg prose-img:max-w-full prose-img:h-auto">
            {{content}}
        </div>

        {{!-- Share Buttons --}}
        <div class="py-4 sm:py-6 border-t border-b border-neutral-200 mb-6 sm:mb-8">
            {{> share-buttons}}
        </div>

        {{!-- Author Bio Section --}}
        <section class="mt-8 sm:mt-10 md:mt-12 pt-6 sm:pt-8 md:pt-10 border-t border-neutral-200">
            <h3 class="text-sm sm:text-base font-semibold text-neutral-500 uppercase tracking-wider mb-4 sm:mb-6">
                {{#has author="count:>1"}}Sobre os Autores{{else}}Sobre o Autor{{/has}}
            </h3>
            <div class="space-y-6 sm:space-y-8">
                {{#foreach authors}}
                <a href="{{url}}" class="flex items-start gap-4 sm:gap-5 md:gap-6 group">
                    {{#if profile_image}}
                    <img src="{{profile_image}}" alt="{{name}}"
                        class="w-16 h-16 sm:w-20 sm:h-20 md:w-24 md:h-24 rounded-full object-cover border-2 border-neutral-100 shadow-sm flex-shrink-0 group-hover:border-primary-200 transition-colors">
                    {{else}}
                    <img src="https://ui-avatars.com/api/?name={{encode name}}&size=96&background=e5e5e5&color=525252&font-size=0.4&bold=true" alt="{{name}}"
                        class="w-16 h-16 sm:w-20 sm:h-20 md:w-24 md:h-24 rounded-full object-cover border-2 border-neutral-100 shadow-sm flex-shrink-0 group-hover:border-primary-200 transition-colors">
                    {{/if}}
                    <div class="flex-1 min-w-0">
                        <h4 class="text-base sm:text-lg md:text-xl font-bold text-neutral-900 group-hover:text-primary-600 transition-colors mb-1 sm:mb-2">
                            {{name}}
                        </h4>
                        {{#if bio}}
                        <p class="text-sm sm:text-base text-neutral-600 leading-relaxed line-clamp-3">
                            {{bio}}
                        </p>
                        {{else}}
                        <p class="text-sm sm:text-base text-neutral-500 italic">
                            Jornalista do O Investigador
                        </p>
                        {{/if}}
                        <span class="inline-block mt-2 sm:mt-3 text-xs sm:text-sm text-primary-600 font-medium group-hover:underline">
                            Ver todos os artigos →
                        </span>
                    </div>
                </a>
                {{/foreach}}
            </div>
        </section>

        {{!-- Related Posts - Mobile First --}}
        <aside class="mt-8 sm:mt-12 md:mt-14 lg:mt-16 pt-8 sm:pt-12 md:pt-14 lg:pt-16 border-t border-neutral-200">
            <h3 class="text-lg sm:text-xl md:text-2xl font-bold mb-4 sm:mb-6 md:mb-8">Leia Também</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6 md:gap-8">
                {{#get "posts" limit="2" filter="tags:[{{tags[*].slug}}]+id:-{{id}}" as |related|}}
                {{#foreach related}}
                {{> post-card}}
                {{/foreach}}
                {{/get}}
            </div>
        </aside>

    </div>
    </article>
    {{/post}}