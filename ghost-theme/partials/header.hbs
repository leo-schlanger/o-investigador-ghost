<header class="sticky top-0 z-50 bg-brand overflow-hidden">

    {{!-- Top Bar: Date, Weather & Social Icons --}}
    <div class="bg-gradient-to-r from-brand-dark via-brand-dark/95 to-brand-dark text-white/90 text-[10px] sm:text-xs py-2 sm:py-2.5">
        <div class="max-w-7xl mx-auto px-3 sm:px-4 md:px-6 flex items-center justify-between">
            {{!-- Date & Weather --}}
            <div class="flex items-center gap-3 sm:gap-4 md:gap-6">
                {{!-- Date with icon --}}
                <div class="flex items-center gap-1.5 sm:gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 sm:w-3.5 sm:h-3.5 text-brand-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                    <time id="header-date-full" class="font-medium hidden sm:block"></time>
                    <time id="header-date-short" class="font-medium sm:hidden"></time>
                </div>
                <span class="w-px h-3 bg-white/20"></span>
                {{!-- Weather with icon --}}
                <div id="weather-widget" class="flex items-center gap-3 sm:gap-4 md:gap-5">
                    <div class="flex items-center gap-1.5">
                        <span class="text-white/50 text-[9px] sm:text-[10px] uppercase tracking-wide hidden sm:inline">Lisboa</span>
                        <span class="text-white/50 text-[9px] uppercase tracking-wide sm:hidden">LIS</span>
                        <span id="weather-lisboa" class="font-semibold text-brand-accent">--</span>
                    </div>
                    <div class="flex items-center gap-1.5">
                        <span class="text-white/50 text-[9px] sm:text-[10px] uppercase tracking-wide hidden sm:inline">Porto</span>
                        <span class="text-white/50 text-[9px] uppercase tracking-wide sm:hidden">PRT</span>
                        <span id="weather-porto" class="font-semibold text-brand-accent">--</span>
                    </div>
                    <div class="hidden sm:flex items-center gap-1.5">
                        <span class="text-white/50 text-[9px] sm:text-[10px] uppercase tracking-wide">Faro</span>
                        <span id="weather-faro" class="font-semibold text-brand-accent">--</span>
                    </div>
                    <div class="hidden md:flex items-center gap-1.5">
                        <span class="text-white/50 text-[9px] sm:text-[10px] uppercase tracking-wide">Cascais</span>
                        <span id="weather-cascais" class="font-semibold text-brand-accent">--</span>
