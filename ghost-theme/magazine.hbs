{{!< default}}
{{!-- Magazine / Reportagens Especiais Template --}}

<div class="bg-neutral-50 min-h-screen">
    {{!-- Hero Section --}}
    <section class="bg-brand text-white py-12 sm:py-16 md:py-20">
        <div class="container-custom text-center">
            <span class="inline-block px-4 py-1.5 bg-brand-accent text-white text-xs font-bold uppercase tracking-wider rounded-full mb-4">
                Reportagens Especiais
            </span>
            <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black mb-4">
                Magazine
            </h1>
            <p class="text-lg sm:text-xl text-white/80 max-w-2xl mx-auto">
                Investigacoes aprofundadas, reportagens exclusivas e series editoriais que marcam a diferenca no jornalismo portugues.
            </p>
        </div>
    </section>

    <div class="container-custom py-8 sm:py-12 md:py-16">
        {{!-- Featured Magazine Article --}}
        {{#get "posts" limit="1" filter="tag:magazine+featured:true" include="authors,tags"}}
        {{#foreach posts}}
        <article class="mb-12 sm:mb-16 md:mb-20">
            <a href="{{url}}" class="group block bg-white rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
                <div class="grid grid-cols-1 lg:grid-cols-2">
                    {{#if feature_image}}
                    <div class="aspect-[16/10] lg:aspect-auto lg:min-h-[400px] overflow-hidden">
                        <img src="{{img_url feature_image size='xl'}}" alt="{{title}}"
                            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                    </div>
                    {{/if}}
                    <div class="p-6 sm:p-8 md:p-10 lg:p-12 flex flex-col justify-center">
                        <div class="flex items-center gap-3 mb-4">
                            <span class="px-3 py-1 bg-brand-accent text-white text-xs font-bold rounded-full uppercase">
                                Destaque
                            </span>
                            <span class="text-sm text-neutral-500">{{reading_time}} min de leitura</span>
                        </div>
                        <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-neutral-900 mb-4 group-hover:text-brand transition-colors leading-tight">
                            {{title}}
                        </h2>
                        <p class="text-neutral-600 text-base sm:text-lg mb-6 line-clamp-3">
                            {{excerpt words="40"}}
                        </p>
                        <div class="flex items-center gap-3">
                            {{#foreach authors}}
                            <div class="flex items-center gap-2">
                                {{#if profile_image}}
                                <img src="{{profile_image}}" alt="{{name}}" class="w-10 h-10 rounded-full object-cover">
                                {{else}}
                                <div class="w-10 h-10 rounded-full bg-neutral-200 flex items-center justify-center text-neutral-500 font-bold text-sm">
                                    {{truncate name 1 ""}}
                                </div>
                                {{/if}}
                                <div>
                                    <span class="block text-sm font-semibold text-neutral-900">{{name}}</span>
                                    <span class="block text-xs text-neutral-500">{{date ../published_at format="D MMM YYYY"}}</span>
                                </div>
                            </div>
                            {{/foreach}}
                        </div>
                    </div>
                </div>
            </a>
        </article>
        {{/foreach}}
        {{/get}}

        {{!-- Magazine Articles Grid --}}
        <section>
            <div class="flex items-center justify-between mb-8">
                <h2 class="text-xl sm:text-2xl md:text-3xl font-black text-neutral-900">
                    Todas as Reportagens
                </h2>
                <span class="text-sm text-neutral-500">
                    {{plural pagination.total empty='Nenhuma reportagem' singular='% reportagem' plural='% reportagens'}}
                </span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
                {{#foreach posts}}
                <article class="bg-white rounded-xl overflow-hidden shadow-md hover:shadow-lg transition-shadow group">
                    <a href="{{url}}" class="block">
                        {{#if feature_image}}
                        <div class="aspect-[16/10] overflow-hidden">
                            <img src="{{img_url feature_image size='m'}}" alt="{{title}}"
                                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                        </div>
                        {{/if}}
                        <div class="p-5 sm:p-6">
                            <div class="flex items-center gap-2 mb-3">
                                {{#if featured}}
                                <span class="px-2 py-0.5 bg-brand-accent/10 text-brand-accent text-[10px] font-bold rounded uppercase">
                                    Destaque
                                </span>
                                {{/if}}
                                <span class="text-xs text-neutral-500">{{reading_time}} min</span>
                            </div>
                            <h3 class="text-lg sm:text-xl font-bold text-neutral-900 mb-3 group-hover:text-brand transition-colors line-clamp-2 leading-snug">
                                {{title}}
                            </h3>
                            <p class="text-sm text-neutral-600 mb-4 line-clamp-2">
                                {{excerpt words="25"}}
                            </p>
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-2">
                                    {{#primary_author}}
                                    {{#if profile_image}}
                                    <img src="{{profile_image}}" alt="{{name}}" class="w-7 h-7 rounded-full object-cover">
                                    {{/if}}
                                    <span class="text-xs font-medium text-neutral-700">{{name}}</span>
                                    {{/primary_author}}
                                </div>
                                <time class="text-xs text-neutral-500">{{date format="D MMM YYYY"}}</time>
                            </div>
                        </div>
                    </a>
                </article>
                {{/foreach}}
            </div>

            {{!-- Pagination --}}
            {{#if pagination.pages}}
            <nav class="mt-12 flex justify-center">
                <div class="flex items-center gap-2">
                    {{#if pagination.prev}}
                    <a href="{{pagination.prev}}" class="px-4 py-2 text-sm font-medium text-neutral-700 bg-white border border-neutral-200 rounded-lg hover:bg-neutral-50 transition">
                        Anterior
                    </a>
                    {{/if}}

                    <span class="px-4 py-2 text-sm font-medium text-neutral-500">
                        Pagina {{pagination.page}} de {{pagination.pages}}
                    </span>

                    {{#if pagination.next}}
                    <a href="{{pagination.next}}" class="px-4 py-2 text-sm font-medium text-white bg-brand rounded-lg hover:bg-brand/90 transition">
                        Proxima
                    </a>
                    {{/if}}
                </div>
            </nav>
            {{/if}}
        </section>

        {{!-- Call to Action --}}
        <section class="mt-16 sm:mt-20 md:mt-24 bg-brand rounded-2xl p-8 sm:p-10 md:p-12 text-center text-white">
            <h2 class="text-2xl sm:text-3xl font-black mb-4">
                Receba as Reportagens em Primeira Mao
            </h2>
            <p class="text-white/80 mb-6 max-w-xl mx-auto">
                Subscreva a nossa newsletter e seja o primeiro a receber as investigacoes e reportagens exclusivas do Magazine.
            </p>
            <form data-members-form="subscribe" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
                <input type="email" name="email" required
                    class="flex-1 px-4 py-3 text-sm bg-white/10 border border-white/20 rounded-lg text-white placeholder-white/50 focus:outline-none focus:border-brand-accent"
                    placeholder="O seu email">
                <button type="submit"
                    class="px-6 py-3 text-sm font-bold uppercase tracking-wide bg-brand-accent hover:bg-brand-accent/90 transition-colors rounded-lg whitespace-nowrap">
                    Subscrever
                </button>
            </form>
        </section>
    </div>
</div>
