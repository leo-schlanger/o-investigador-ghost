<!DOCTYPE html>
<html lang="{{@site.locale}}">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{meta_title}}</title>

    {{!-- Favicon --}}
    <link rel="icon" type="image/jpeg" href="{{asset 'images/logo.jpg'}}">
    <link rel="apple-touch-icon" href="{{asset 'images/logo.jpg'}}">
    <meta name="api-url" content="https://api.jornalinvestigador.pt">

    {{!-- Fonts (preconnect required for theme-loaded Google Fonts) --}}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700;800&family=Playfair+Display:wght@700;800;900&display=swap"
        rel="stylesheet">

    {{!-- Main CSS --}}
    <link rel="stylesheet" href="{{asset 'css/screen.css'}}">

    {{!-- Ghost handles SEO: description, canonical, OG, Twitter Card, Schema.org --}}
    {{!-- og:image, twitter:image set via Ghost Admin (Settings > General > Social) --}}
    {{ghost_head}}

    {{!-- SEO overrides AFTER ghost_head --}}
    <meta property="og:locale" content="pt_PT">
    <meta name="language" content="pt-PT">

    {{!-- Override Ghost's English twitter labels with Portuguese --}}
    <meta name="twitter:label1" content="Escrito por">
    <meta name="twitter:label2" content="Categoria">

    {{!-- Fallback og:image for ANY page without a feature image --}}
    {{#unless feature_image}}
    {{#is "post"}}
    {{!-- Articles without feature_image: Ghost already outputs og:image from cover_image --}}
    {{else}}
    <meta property="og:image" content="{{@site.url}}/assets/images/og-default.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta name="twitter:image" content="{{@site.url}}/assets/images/og-default.png">
    <meta name="twitter:card" content="summary_large_image">
    {{/is}}
    {{/unless}}

    {{!-- Better og:description for tag pages --}}
    {{#is "tag"}}
    {{#tag}}
    <meta property="og:description" content="{{#if description}}{{description}}{{else}}Artigos sobre {{name}} no jornal O Investigador.{{/if}}">
    <meta name="twitter:description" content="{{#if description}}{{description}}{{else}}Artigos sobre {{name}} no jornal O Investigador.{{/if}}">
    {{/tag}}
    {{/is}}

    {{!-- Additional Schema.org: NewsMediaOrganization (not generated by Ghost) --}}
    {{> schema}}
</head>

<body class="{{body_class}} bg-white text-neutral-900">
    <a href="#main-content" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0" onfocus="this.style.cssText='position:absolute;top:8px;left:8px;z-index:100;padding:8px 16px;background:#1a2744;color:#fff;border-radius:8px;font-weight:600;font-size:14px'" onblur="this.style.cssText='position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0'">
        Saltar para o conteúdo
    </a>
    {{> header}}

    <main id="main-content">
        {{{body}}}
    </main>

    {{> footer}}

    {{!-- Search Modal --}}
    {{> search-modal}}

    <script src="{{asset 'js/ads-integrator.js'}}"></script>
    <script src="{{asset 'js/view-tracker.js'}}"></script>
    <script src="{{asset 'js/search.js'}}"></script>
    {{ghost_foot}}
</body>

</html>