{
    "name": "o-investigador-api",
    "version": "1.0.0",
    "description": "Custom API for O Investigador",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src/ server.js --max-warnings=0",
        "lint:fix": "eslint src/ server.js --fix",
        "format": "prettier --write \"src/**/*.js\" server.js",
        "format:check": "prettier --check \"src/**/*.js\" server.js",
        "sync:avatars": "node scripts/sync-avatars.js"
    },
    "dependencies": {
        "@tryghost/admin-api": "^1.13.7",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "exceljs": "^4.4.0",
        "express": "^4.18.2",
        "express-rate-limit": "^8.3.1",
        "geoip-lite": "^1.4.10",
        "helmet": "^8.1.0",
        "ioredis": "^5.10.1",
        "joi": "^17.9.2",
        "jsonwebtoken": "^9.0.1",
        "multer": "^1.4.5-lts.1",
        "mysql2": "^3.6.0",
        "pdfkit": "^0.15.0",
        "pdfkit-table": "^0.1.99",
        "sequelize": "^6.32.1",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "winston": "^3.19.0"
    },
    "devDependencies": {
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "jest": "^29.7.0",
        "nodemon": "^3.1.11",
        "prettier": "^3.8.1",
        "supertest": "^6.3.3"
    }
}
