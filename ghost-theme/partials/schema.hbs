{{!-- Schema.org JSON-LD: NewsMediaOrganization (Ghost already generates WebSite schema) --}}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "NewsMediaOrganization",
    "name": "{{@site.title}}",
    "url": "{{@site.url}}",
    {{#if @site.logo}}
    "logo": {
        "@type": "ImageObject",
        "url": "{{@site.logo}}"
    },
    {{/if}}
    "sameAs": []
}
</script>
