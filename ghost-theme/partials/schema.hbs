{{!-- Schema.org JSON-LD Structured Data --}}

{{!-- Organization Schema (for all pages) --}}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "NewsMediaOrganization",
    "name": "{{@site.title}}",
    "url": "{{@site.url}}",
    {{#if @site.logo}}
    "logo": {
        "@type": "ImageObject",
        "url": "{{@site.logo}}"
    },
    {{/if}}
    "sameAs": [
        {{#if @site.facebook}}"https://facebook.com/{{@site.facebook}}"{{/if}}{{#if @site.twitter}}{{#if @site.facebook}},{{/if}}"https://twitter.com/{{@site.twitter}}"{{/if}}
    ]
}
</script>

{{!-- WebSite Schema with SearchAction --}}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "{{@site.title}}",
    "url": "{{@site.url}}",
    "potentialAction": {
        "@type": "SearchAction",
        "target": "{{@site.url}}/?s={search_term_string}",
        "query-input": "required name=search_term_string"
    }
}
</script>

{{!-- Article Schema (only for posts) --}}
{{#is "post"}}
{{#post}}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "{{url absolute="true"}}"
    },
    "headline": "{{title}}",
    "description": "{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="30"}}{{/if}}",
    {{#if feature_image}}
    "image": {
        "@type": "ImageObject",
        "url": "{{feature_image}}",
        "width": 1200,
        "height": 630
    },
    {{/if}}
    "datePublished": "{{date published_at format="YYYY-MM-DDTHH:mm:ssZ"}}",
    "dateModified": "{{date updated_at format="YYYY-MM-DDTHH:mm:ssZ"}}",
    "author": {
        "@type": "Person",
        "name": "{{primary_author.name}}",
        {{#if primary_author.profile_image}}
        "image": "{{primary_author.profile_image}}",
        {{/if}}
        "url": "{{primary_author.url absolute="true"}}"
    },
    "publisher": {
        "@type": "Organization",
        "name": "{{@site.title}}",
        {{#if @site.logo}}
        "logo": {
            "@type": "ImageObject",
            "url": "{{@site.logo}}"
        }
        {{/if}}
    },
    {{#if primary_tag}}
    "articleSection": "{{primary_tag.name}}",
    {{/if}}
    {{#if tags}}
    "keywords": "{{#foreach tags}}{{name}}{{#unless @last}}, {{/unless}}{{/foreach}}",
    {{/if}}
    "wordCount": {{reading_time}},
    "isAccessibleForFree": true
}
</script>
{{/post}}
{{/is}}

{{!-- BreadcrumbList Schema --}}
{{#is "post"}}
{{#post}}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{@site.url}}"
        }
        {{#if primary_tag}}
        ,{
            "@type": "ListItem",
            "position": 2,
            "name": "{{primary_tag.name}}",
            "item": "{{primary_tag.url absolute="true"}}"
        }
        ,{
            "@type": "ListItem",
            "position": 3,
            "name": "{{title}}",
            "item": "{{url absolute="true"}}"
        }
        {{else}}
        ,{
            "@type": "ListItem",
            "position": 2,
            "name": "{{title}}",
            "item": "{{url absolute="true"}}"
        }
        {{/if}}
    ]
}
</script>
{{/post}}
{{/is}}

{{!-- Tag/Category Page Schema --}}
{{#is "tag"}}
{{#tag}}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "{{name}}",
    "description": "{{#if description}}{{description}}{{else}}Artigos sobre {{name}}{{/if}}",
    "url": "{{url absolute="true"}}",
    "isPartOf": {
        "@type": "WebSite",
        "name": "{{@site.title}}",
        "url": "{{@site.url}}"
    }
}
</script>
{{/tag}}
{{/is}}

{{!-- Author Page Schema --}}
{{#is "author"}}
{{#author}}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    "mainEntity": {
        "@type": "Person",
        "name": "{{name}}",
        {{#if bio}}
        "description": "{{bio}}",
        {{/if}}
        {{#if profile_image}}
        "image": "{{profile_image}}",
        {{/if}}
        {{#if website}}
        "url": "{{website}}",
        {{/if}}
        "sameAs": [
            {{#if facebook}}"https://facebook.com/{{facebook}}"{{/if}}{{#if twitter}}{{#if facebook}},{{/if}}"https://twitter.com/{{twitter}}"{{/if}}
        ]
    }
}
</script>
{{/author}}
{{/is}}
