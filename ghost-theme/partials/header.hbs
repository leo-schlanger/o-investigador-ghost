                    <a href="/politica/" class="text-sm text-neutral-600 hover:text-brand hover:bg-primary-50 transition px-3 py-2 rounded-lg">Politica</a>
                    <a href="/economia/" class="text-sm text-neutral-600 hover:text-brand hover:bg-primary-50 transition px-3 py-2 rounded-lg">Economia</a>
                    <a href="/justica/" class="text-sm text-neutral-600 hover:text-brand hover:bg-primary-50 transition px-3 py-2 rounded-lg">Justica</a>
                    <a href="/internacional/" class="text-sm text-neutral-600 hover:text-brand hover:bg-primary-50 transition px-3 py-2 rounded-lg">Internacional</a>
                    <a href="/sociedade/" class="text-sm text-neutral-600 hover:text-brand hover:bg-primary-50 transition px-3 py-2 rounded-lg">Sociedade</a>
                    <a href="/saude/" class="text-sm text-neutral-500 hover:text-brand hover:bg-primary-50 transition px-3 py-2 rounded-lg pl-6">Saude</a>
                    <a href="/educacao/" class="text-sm text-neutral-500 hover:text-brand hover:bg-primary-50 transition px-3 py-2 rounded-lg pl-6">Educacao</a>
                    <a href="/ambiente/" class="text-sm text-neutral-600 hover:text-brand hover:bg-primary-50 transition px-3 py-2 rounded-lg">Ambiente</a>
