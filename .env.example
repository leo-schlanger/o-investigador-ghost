# --- Geral ---
NODE_ENV=development

# --- Banco de Dados (MySQL) ---
DB_HOST=mysql
DB_PORT=3306
DB_ROOT_PASSWORD=secure_root_password
DB_NAME=o_investigador
DB_USER=ghost
DB_PASSWORD=changeme_secure_password_123

# --- Ghost CMS ---
GHOST_URL=http://localhost:2368

# IMPORTANT: In PRODUCTION, use the PUBLIC URL (https://yourdomain.com)
# Ghost validates that API requests match its configured URL
# In DEVELOPMENT, use internal Docker network URL
GHOST_API_URL=http://ghost:2368
# Mails (Configure Mailgun ou SendGrid para produção)
GHOST_MAIL_FROM=noreply@oseudominio.com

# --- API Keys do Ghost (VER README PARA INSTRUÇÕES) ---
# Content API Key: Usada para leitura pública
GHOST_API_KEY=

# --- API Customizada & Segurança ---
# IMPORTANTE: Gere um secret de 64+ bytes para produção: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_A_SECURE_64_BYTE_SECRET_FOR_PRODUCTION
CORS_ORIGIN=http://localhost:2368,http://localhost:5173,http://localhost:3001

# --- Admin Panel ---
VITE_API_URL=http://localhost:3001
VITE_GHOST_URL=http://localhost:2368

# --- Redis Cache (Opcional) ---
# Se não configurado, cache será desabilitado
# Para autenticação: redis://:SUA_SENHA@redis:6379
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# --- Serviços Externos (Opcionais Localmente) ---
# Email
SENDGRID_API_KEY=

# AWS S3 (Armazenamento de Mídia)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_BUCKET=o-investigador-media

# --- reCAPTCHA v3 (Opcional) ---
# Se configurado, protege formulário de contacto
RECAPTCHA_SECRET_KEY=

# --- Monitoring (Grafana + Loki) ---
# Password for Grafana admin user
GRAFANA_ADMIN_PASSWORD=
