{{!< default}} {{!-- JN Layout: Boxy, Grid-based, Information Dense - Mobile First --}}

{{!-- Trending News Bar --}}
{{#get "posts" limit="6" filter="featured:true" include="tags"}}
{{#if posts}}
<div class="bg-brand-dark text-white py-2 sm:py-2.5 overflow-hidden">
    <div class="container-custom">
        <div class="flex items-center gap-3 sm:gap-4">
            <span class="flex-shrink-0 bg-brand-accent text-white text-xs font-bold px-2.5 sm:px-3 py-1 rounded uppercase tracking-wider animate-pulse">
                Agora
            </span>
            <div class="relative flex-1 overflow-hidden min-w-0">
                <div id="trending-carousel" class="flex transition-transform duration-500 ease-in-out">
                    {{#foreach posts}}
                    <a href="{{url}}" class="flex-shrink-0 w-full text-sm sm:text-base font-medium hover:text-primary-200 transition truncate py-1">
                        <span class="text-primary-200 mr-2">{{primary_tag.name}}:</span>
                        {{title}}
                    </a>
                    {{/foreach}}
                </div>
            </div>
            <div class="flex-shrink-0 flex items-center gap-0.5">
                <button id="trending-prev" class="p-2 min-w-[44px] min-h-[44px] flex items-center justify-center text-white/70 hover:text-white transition" aria-label="Anterior">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="15 18 9 12 15 6"></polyline>
                    </svg>
                </button>
                <button id="trending-next" class="p-2 min-w-[44px] min-h-[44px] flex items-center justify-center text-white/70 hover:text-white transition" aria-label="Próximo">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</div>
<script>
(function() {
    const carousel = document.getElementById('trending-carousel');
    const prevBtn = document.getElementById('trending-prev');
    const nextBtn = document.getElementById('trending-next');
    if (!carousel) return;

    const items = carousel.children;
    const total = items.length;
    let current = 0;
    let autoSlide;

    function goTo(index) {
        current = (index + total) % total;
        carousel.style.transform = `translateX(-${current * 100}%)`;
    }

    function next() { goTo(current + 1); }
    function prev() { goTo(current - 1); }

    function startAuto() {
        autoSlide = setInterval(next, 4000);
    }

    function stopAuto() {
        clearInterval(autoSlide);
    }

    prevBtn?.addEventListener('click', () => { stopAuto(); prev(); startAuto(); });
    nextBtn?.addEventListener('click', () => { stopAuto(); next(); startAuto(); });

    carousel.parentElement?.addEventListener('mouseenter', stopAuto);
    carousel.parentElement?.addEventListener('mouseleave', startAuto);

    startAuto();
})();
</script>
{{/if}}
{{/get}}

<div class="container-custom pt-3 sm:pt-4 md:pt-6 pb-6 sm:pb-8 md:pb-12 overflow-hidden">

    {{!-- Last Update Timestamp --}}
    <div class="flex items-center justify-end text-[10px] sm:text-xs text-neutral-500 mb-3 sm:mb-4">
        <span id="last-update-container" class="inline-flex items-center gap-2 bg-neutral-50 border border-neutral-200 px-3 py-1.5 rounded-full">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-neutral-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
            <span class="text-neutral-400">Atualizado:</span>
            <span id="last-update-time" class="font-medium text-neutral-600"></span>
        </span>
    </div>
    <script>
    (function() {
        var mesesAbrev = ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'];
        var agora = new Date();
        var dia = agora.getDate();
        var mes = mesesAbrev[agora.getMonth()];
        var ano = agora.getFullYear();
        var hora = agora.getHours().toString().padStart(2, '0');
        var minuto = agora.getMinutes().toString().padStart(2, '0');
        var el = document.getElementById('last-update-time');
        if (el) el.textContent = dia + ' ' + mes + ' ' + ano + ', ' + hora + ':' + minuto;
    })();
    </script>

    {{!-- TOP AD: Leaderboard --}}
    {{> ad-slot type="leaderboard" label="Publicidade" slotId="header_leaderboard"}}

    {{!-- HERO SECTION: JN Style (Main Left + Vertical List Right) - Mobile First --}}
    {{#get "posts" limit="5" filter="featured:true" include="authors,tags" as |featured|}}
    {{#if featured}}
    <section
        class="grid grid-cols-1 lg:grid-cols-12 gap-4 md:gap-6 lg:gap-8 mb-6 md:mb-8 lg:mb-12 border-b border-neutral-200 pb-6 md:pb-8 lg:pb-12">

        {{!-- Main Headline (Big Photo) - Mobile First --}}
        {{#foreach featured to="1"}}
        <div class="lg:col-span-8 group min-w-0">
            <a href="{{url}}" class="block relative aspect-[4/3] sm:aspect-[16/9] mb-3 md:mb-4 overflow-hidden rounded-sm">
                {{#if feature_image}}
                <img src="{{img_url feature_image size='xl'}}"
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    alt="{{title}}" loading="eager">
                {{/if}}
                <div
                    class="absolute bottom-0 left-0 bg-brand-accent text-white text-[10px] sm:text-xs font-bold px-2 sm:px-3 py-1 uppercase tracking-widest">
                    {{primary_tag.name}}
                </div>
            </a>
            <h1
                class="text-lg sm:text-xl md:text-3xl lg:text-4xl xl:text-5xl font-black mb-2 md:mb-3 leading-tight group-hover:text-brand-accent transition-colors">
                <a href="{{url}}">{{title}}</a>
            </h1>
            <p class="text-sm md:text-base lg:text-lg text-neutral-600 leading-relaxed">{{excerpt words="50"}}</p>
        </div>
        {{/foreach}}

        {{!-- Secondary List (Vertical) - Mobile: vertical compact, Desktop: vertical --}}
        <div
            class="lg:col-span-4 flex flex-col gap-3 sm:gap-4 md:gap-6 lg:border-l border-neutral-100 lg:pl-6 xl:pl-8 mt-4 sm:mt-6 lg:mt-0 min-w-0">
            {{#foreach featured from="2"}}
            <article class="group relative min-w-0">
                <div class="mb-1 sm:mb-2">
                    <span class="tag-label">{{primary_tag.name}}</span>
                </div>
                <h3
                    class="text-sm sm:text-base md:text-lg lg:text-xl font-bold leading-snug group-hover:text-brand-accent transition-colors line-clamp-3">
                    <a href="{{url}}">{{title}}</a>
                </h3>
                <div class="text-[11px] sm:text-xs text-neutral-400 mt-1.5 sm:mt-2 flex items-center gap-2">
                    <time>{{date format="HH:mm"}}</time> | {{authors}}
                </div>
            </article>
            {{#unless @last}}
            <hr class="border-neutral-100">{{/unless}}
            {{/foreach}}
        </div>

    </section>
    {{/if}}
    {{/get}}


    {{!-- MAIN GRID: Content (8) | Sidebar (4) - Mobile First --}}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 sm:gap-6 md:gap-8">

        {{!-- LEFT COLUMN: Sections & Latest --}}
        <div class="lg:col-span-8 min-w-0">

            {{!-- SECTION: Últimas (Cards with Image on Top) --}}
            <section class="mb-6 sm:mb-8 md:mb-10 lg:mb-12">
                <h2 class="section-title">Últimas</h2>
                {{#get "posts" limit="6" include="tags,authors" filter="featured:false"}}
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5 md:gap-6">
                    {{#foreach posts}}
                    <article class="group bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow border border-neutral-100">
                        {{!-- Image on top --}}
                        <a href="{{url}}" class="block relative aspect-[16/10] overflow-hidden bg-neutral-100">
                            {{#if feature_image}}
                            <img src="{{img_url feature_image size="m"}}"
                                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                                alt="{{title}}" loading="lazy">
                            {{else}}
                            <div class="w-full h-full bg-gradient-to-br from-neutral-100 to-neutral-200 flex items-center justify-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-neutral-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                            </div>
                            {{/if}}
                            {{!-- Category badge on image --}}
                            {{#if primary_tag}}
                            <span class="absolute top-3 left-3 bg-brand text-white text-[10px] sm:text-xs font-semibold px-2 py-1 rounded uppercase tracking-wide">
                                {{primary_tag.name}}
                            </span>
                            {{/if}}
                        </a>
                        {{!-- Content below --}}
                        <div class="p-4">
                            <h3 class="text-base sm:text-lg font-bold leading-snug mb-2 group-hover:text-brand-accent transition-colors line-clamp-2">
                                <a href="{{url}}">{{title}}</a>
                            </h3>
                            <p class="text-sm text-neutral-600 line-clamp-2 mb-3">{{excerpt words="20"}}</p>
                            <time class="text-xs text-neutral-400">{{date format="D MMM YYYY"}}</time>
                        </div>
                    </article>
                    {{/foreach}}
                </div>
                {{/get}}
            </section>

            {{!-- ADS --}}
            {{> ad-slot type="leaderboard" label="Publicidade" slotId="middle_leaderboard"}}

            {{!-- SECTIONS (Economy, Politics) - Mobile First --}}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-6 md:gap-8 mt-6 sm:mt-8 md:mt-10 lg:mt-12">

                {{!-- ECONOMY - Mobile First --}}
                <div class="border-t-4 border-black pt-3 md:pt-4 min-w-0">
                    <h2
                        class="text-base sm:text-lg md:text-xl lg:text-2xl font-black uppercase mb-3 sm:mb-4 md:mb-6 flex items-center gap-2">
                        <span class="w-2.5 h-2.5 sm:w-3 sm:h-3 bg-brand-accent inline-block flex-shrink-0"></span>
                        Economia
                    </h2>
                    {{#get "posts" limit="3" filter="tag:economia"}}
                    <div class="flex flex-col gap-3 sm:gap-4 md:gap-6">
                        {{#foreach posts}}
                        <article class="group min-w-0">
                            <h3
                                class="text-sm sm:text-base md:text-lg font-bold leading-snug group-hover:text-brand-accent line-clamp-3">
                                <a href="{{url}}">{{title}}</a>
                            </h3>
                            <p class="text-xs sm:text-sm text-neutral-500 line-clamp-2 mt-1">{{excerpt words="25"}}</p>
                        </article>
                        {{/foreach}}
                    </div>
                    {{/get}}
                </div>

                {{!-- POLITICS - Mobile First --}}
                <div class="border-t-4 border-black pt-3 md:pt-4 min-w-0">
                    <h2
                        class="text-base sm:text-lg md:text-xl lg:text-2xl font-black uppercase mb-3 sm:mb-4 md:mb-6 flex items-center gap-2">
                        <span class="w-2.5 h-2.5 sm:w-3 sm:h-3 bg-brand-accent inline-block flex-shrink-0"></span>
                        Política
                    </h2>
                    {{#get "posts" limit="3" filter="tag:politica"}}
                    <div class="flex flex-col gap-3 sm:gap-4 md:gap-6">
                        {{#foreach posts}}
                        <article class="group min-w-0">
                            <h3
                                class="text-sm sm:text-base md:text-lg font-bold leading-snug group-hover:text-brand-accent line-clamp-3">
                                <a href="{{url}}">{{title}}</a>
                            </h3>
                            <p class="text-xs sm:text-sm text-neutral-500 line-clamp-2 mt-1">{{excerpt words="25"}}</p>
                        </article>
                        {{/foreach}}
                    </div>
                    {{/get}}
                </div>

            </div>

        </div>

        {{!-- SIDEBAR: Ads & Most Read - Mobile First --}}
        <aside class="lg:col-span-4 space-y-4 sm:space-y-6 md:space-y-8 lg:space-y-12 mt-6 sm:mt-8 lg:mt-0 min-w-0">

            {{!-- MPU Ad --}}
            {{> ad-slot type="mpu" label="Publicidade" slotId="sidebar_mpu_1"}}

            {{!-- Most Read - Fetches most recent posts as proxy for popularity --}}
            <div class="bg-neutral-50 p-3 sm:p-4 md:p-6 border-t-4 border-brand-accent">
                <h3 class="text-base sm:text-lg md:text-xl font-black uppercase mb-3 sm:mb-4 md:mb-6">Mais Lidas</h3>
                {{!-- Dynamic most viewed list - populated by view-tracker.js, fallback to recent posts --}}
                <ol id="most-viewed-list" class="space-y-2.5 sm:space-y-3 md:space-y-4 text-neutral-900">
                    {{#get "posts" limit="5" order="published_at desc" include="authors"}}
                    {{#foreach posts}}
                    <li class="flex gap-2 border-b border-neutral-200 pb-2 last:border-0 group">
                        <span class="text-brand-accent font-black text-sm sm:text-base md:text-lg">{{@number}}.</span>
                        <a href="{{url}}" class="font-bold text-xs sm:text-sm md:text-base lg:text-lg hover:text-brand-accent transition-colors line-clamp-2">
                            {{title}}
                        </a>
                    </li>
                    {{/foreach}}
                    {{else}}
                    <li class="text-sm text-neutral-500">Nenhum artigo disponível.</li>
                    {{/get}}
                </ol>
            </div>

            {{!-- Newsletter Signup (Ghost Members) --}}
            <div class="bg-brand-dark text-white p-4 sm:p-5 md:p-6 rounded-sm">
                <h3 class="text-base sm:text-lg md:text-xl font-black uppercase mb-2 sm:mb-3">Newsletter</h3>
                <p class="text-xs sm:text-sm text-white/80 mb-3 sm:mb-4">Receba as principais notícias diretamente no seu email.</p>
                <form data-members-form="subscribe" class="flex flex-col gap-2 sm:gap-3">
                    <input type="email" name="email" required
                        class="w-full px-3 py-2 text-sm bg-white/10 border border-white/20 rounded-sm text-white placeholder-white/50 focus:outline-none focus:border-brand-accent"
                        placeholder="Seu email">
                    <button type="submit"
                        class="w-full px-4 py-2 text-xs sm:text-sm font-bold uppercase tracking-wide bg-brand-accent hover:bg-brand-accent/90 transition-colors rounded-sm">
                        Subscrever
                    </button>
                    <p class="text-[10px] sm:text-xs text-white/50 hidden" data-members-error></p>
                    <p class="text-[10px] sm:text-xs text-green-400 hidden" data-members-success>Obrigado por subscrever!</p>
                </form>
            </div>

            {{!-- MPU Ad 2 --}}
            {{> ad-slot type="mpu" label="Publicidade" slotId="sidebar_mpu_2"}}

        </aside>

    </div>

    </div>